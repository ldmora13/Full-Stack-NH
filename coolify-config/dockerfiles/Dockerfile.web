FROM node:20-alpine AS builder
WORKDIR /app

# Copy submodule content (output: 'static' in astro.config.mjs)
COPY web/ .

RUN npm ci
RUN npm run build

# Serve the static output with nginx
FROM nginx:alpine AS runner

COPY --from=builder /app/dist /usr/share/nginx/html

# Config for Astro static site behind Traefik reverse proxy
RUN printf 'server {\n\
  listen 4321;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  port_in_redirect off;\n\
  absolute_redirect off;\n\
  location / {\n\
    try_files $uri $uri/ $uri.html =404;\n\
  }\n\
  gzip on;\n\
  gzip_types text/css application/javascript image/svg+xml;\n\
}' > /etc/nginx/conf.d/default.conf

EXPOSE 4321
CMD ["nginx", "-g", "daemon off;"]